{
  "name": "medvirtual-meta-content-doc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "generate:vma": "node scripts/generate-vma-site.mjs",
    "generate:images": "node scripts/generate-image-variations.mjs",
    "generate:handoff": "node scripts/generate-handoff-docs.mjs",
    "generate:templates": "node scripts/generate-template-board.mjs",
    "generate:hub": "node scripts/generate-asset-hub.mjs",
    "generate:brand-guide": "node scripts/generate-brand-guide.mjs",
    "generate:copy": "node scripts/generate-ad-copy.mjs",
    "generate:brief": "node scripts/generate-graphic-request-brief.mjs",
    "generate:studio": "node scripts/generate-vma-site.mjs",
    "generate:ideas": "node scripts/generate-vma-site.mjs",
    "generate:competitors": "node scripts/generate-competitor-wall.mjs",
    "generate:competitor-snaps": "node scripts/generate-competitor-snapshots.mjs",
    "generate:mockups": "node scripts/generate-mockup-sandbox.mjs",
    "generate:creative-lab": "node scripts/generate-creative-concept-lab.mjs",
    "generate:motion-lab": "node scripts/generate-motion-concept-lab.mjs",
    "generate:marketing-library": "node scripts/generate-marketing-library.mjs",
    "import:marketing-library": "node scripts/import-marketing-library.mjs && node scripts/generate-marketing-library.mjs",
    "import:brand-pack": "node scripts/import-brand-pack.mjs",
    "generate:raw-assets": "node scripts/generate-raw-assets.mjs",
    "generate:foundry": "node scripts/generate-foundry-page.mjs",
    "generate:video": "node scripts/generate-video-production.mjs",
    "generate:video-data": "node scripts/generate-video-production-data.mjs",
    "generate:docs": "node scripts/generate-vma-site.mjs && node scripts/generate-raw-assets.mjs && node scripts/generate-competitor-wall.mjs && node scripts/generate-asset-hub.mjs && node scripts/generate-brand-guide.mjs && node scripts/generate-graphic-request-brief.mjs && node scripts/generate-foundry-page.mjs",
    "remotion:studio": "remotion studio src/remotion/index.js",
    "assets:foundry-api": "node --env-file=.env.local scripts/asset-foundry/local-api.mjs",
    "assets:pull-approved": "node --env-file=.env.local scripts/asset-foundry/pull-approved.mjs"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.489",
    "@remotion/player": "^4.0.489",
    "@vercel/blob": "^2.6.1",
    "html-to-image": "^1.11.13",
    "openai": "^6.46.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "remotion": "^4.0.489",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
